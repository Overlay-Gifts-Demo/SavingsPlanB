<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <title>AR Experience</title>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --gold: #c9a84c;
      --gold-light: #e8cc80;
      --gold-dim: rgba(201,168,76,0.18);
      --glass: rgba(10,10,12,0.72);
      --glass-border: rgba(201,168,76,0.22);
      --text: #f0ece4;
      --muted: rgba(240,236,228,0.45);
    }

    html, body {
      width: 100%; height: 100%;
      overflow: hidden;
      background: #000;
      font-family: 'DM Mono', monospace;
      color: var(--text);
    }

    /* ── Camera ── */
    #cam {
      position: fixed; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      z-index: 0;
    }

    /* ── Vignette overlay ── */
    #vignette {
      position: fixed; inset: 0; z-index: 1;
      background: radial-gradient(ellipse at center, transparent 42%, rgba(0,0,0,0.72) 100%);
      pointer-events: none;
    }

    /* ── Scan-line grain ── */
    #grain {
      position: fixed; inset: 0; z-index: 2; pointer-events: none; opacity: 0.04;
      background-image: repeating-linear-gradient(0deg, rgba(255,255,255,0.1) 0px, transparent 1px, transparent 3px);
      background-size: 100% 4px;
    }

    /* ── Corner brackets ── */
    .corner {
      position: fixed; z-index: 3; width: 28px; height: 28px;
      pointer-events: none;
      opacity: 0.55;
    }
    .corner::before, .corner::after {
      content: ''; position: absolute; background: var(--gold);
    }
    .corner::before { width: 2px; height: 100%; }
    .corner::after  { width: 100%; height: 2px; }
    .corner.tl { top: 18px; left: 18px; }
    .corner.tr { top: 18px; right: 18px; transform: scaleX(-1); }
    .corner.bl { bottom: 18px; left: 18px; transform: scaleY(-1); }
    .corner.br { bottom: 18px; right: 18px; transform: scale(-1); }

    /* ── Top bar ── */
    #topbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 10;
      display: flex; align-items: center; justify-content: space-between;
      padding: 18px 28px 14px;
      background: linear-gradient(to bottom, rgba(0,0,0,0.65) 0%, transparent 100%);
    }
    #logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 19px; font-weight: 600; letter-spacing: 0.18em;
      color: var(--gold-light);
      text-transform: uppercase;
    }
    #logo span { opacity: 0.5; margin: 0 6px; font-weight: 300; }

    #status-dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: #4caf87;
      box-shadow: 0 0 8px #4caf87;
      animation: pulse 2.2s infinite;
    }
    @keyframes pulse {
      0%,100% { opacity: 1; } 50% { opacity: 0.35; }
    }

    /* ── Ad video ── */
    #ad {
      position: fixed;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%) scale(0.94);
      max-width: min(88vw, 520px);
      max-height: 56vh;
      width: auto; height: auto;
      border-radius: 14px;
      display: none;
      z-index: 6;
      background: #000;
      box-shadow:
        0 0 0 1.5px var(--glass-border),
        0 0 60px rgba(201,168,76,0.12),
        0 32px 80px rgba(0,0,0,0.75);
      transition: transform 0.5s cubic-bezier(.22,1,.36,1), opacity 0.4s;
      opacity: 0;
    }
    #ad.visible {
      transform: translate(-50%, -50%) scale(1);
      opacity: 1;
    }

    /* ── Play/Pause ── */
    #ppBtn {
      position: fixed;
      z-index: 12;
      bottom: 178px; left: 50%;
      transform: translateX(-50%);
      width: 52px; height: 52px;
      border-radius: 50%;
      border: 1.5px solid var(--gold);
      background: var(--glass);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      color: var(--gold-light);
      font-size: 18px;
      cursor: pointer;
      display: none;
      align-items: center; justify-content: center;
      box-shadow: 0 0 24px rgba(201,168,76,0.2), 0 4px 16px rgba(0,0,0,0.5);
      transition: background 0.2s, transform 0.15s;
    }
    #ppBtn:active { transform: translateX(-50%) scale(0.92); }

    /* ── Plan label ── */
    #planLabel {
      position: fixed; bottom: 234px; left: 50%;
      transform: translateX(-50%);
      z-index: 11;
      font-size: 10px; letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--gold);
      opacity: 0;
      transition: opacity 0.35s;
      pointer-events: none;
      white-space: nowrap;
    }
    #planLabel.show { opacity: 1; }

    /* ── Thumbnail bar ── */
    .thumbnail-bar {
      position: fixed;
      bottom: 80px; left: 50%;
      transform: translateX(-50%);
      display: flex; gap: 12px;
      z-index: 10;
    }

    .thumbnail {
      position: relative;
      width: 80px; height: 52px;
      border-radius: 10px;
      border: 1.5px solid rgba(201,168,76,0.25);
      background: var(--glass);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      cursor: pointer;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      gap: 3px;
      transition: border-color 0.25s, box-shadow 0.25s, transform 0.2s;
      overflow: hidden;
    }
    .thumbnail::before {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(201,168,76,0.06) 0%, transparent 70%);
      border-radius: inherit;
    }
    .thumbnail:active { transform: scale(0.94); }
    .thumbnail .t-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 16px; font-weight: 600;
      color: var(--gold-light); line-height: 1;
    }
    .thumbnail .t-label {
      font-size: 8px; letter-spacing: 0.2em;
      color: var(--muted); text-transform: uppercase;
    }
    .thumbnail.selected {
      border-color: var(--gold);
      box-shadow: 0 0 20px rgba(201,168,76,0.3), inset 0 0 14px rgba(201,168,76,0.07);
    }
    .thumbnail.selected .t-num { color: var(--gold-light); }
    .thumbnail.selected .t-label { color: var(--gold); }

    /* ── Bottom bar ── */
    #bottombar {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 10;
      padding: 0 28px 18px;
      display: flex; justify-content: space-around; align-items: center;
      background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, transparent 100%);
    }

    .bar-btn {
      display: flex; flex-direction: column; align-items: center; gap: 5px;
      background: none; border: none; cursor: pointer;
      color: var(--muted); font-size: 8px; letter-spacing: 0.18em;
      text-transform: uppercase;
      transition: color 0.2s;
      padding: 4px 10px;
      font-family: 'DM Mono', monospace;
    }
    .bar-btn svg { width: 22px; height: 22px; stroke: currentColor; fill: none; stroke-width: 1.4; }
    .bar-btn:hover, .bar-btn:focus { color: var(--gold-light); }
    .bar-btn:active { color: var(--gold); }

    /* ── Toast ── */
    #toast {
      position: fixed; top: 72px; left: 50%;
      transform: translateX(-50%) translateY(-8px);
      background: var(--glass);
      border: 1px solid var(--glass-border);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      border-radius: 40px;
      padding: 8px 20px;
      font-size: 11px; letter-spacing: 0.16em;
      color: var(--gold-light);
      z-index: 99;
      opacity: 0; pointer-events: none;
      transition: opacity 0.3s, transform 0.3s;
    }
    #toast.show {
      opacity: 1; transform: translateX(-50%) translateY(0);
    }

    /* ── Shimmer on selected thumbnail ── */
    @keyframes shimmer {
      0%   { transform: translateX(-100%) skewX(-12deg); }
      100% { transform: translateX(220%) skewX(-12deg); }
    }
    .thumbnail.selected::after {
      content: '';
      position: absolute; top: 0; left: 0;
      width: 45%; height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08), transparent);
      animation: shimmer 2.4s ease-in-out infinite;
    }
  </style>
</head>
<body>

<!-- Camera feed -->
<video id="cam" autoplay muted playsinline></video>

<!-- Overlays -->
<div id="vignette"></div>
<div id="grain"></div>

<!-- Corners -->
<div class="corner tl"></div>
<div class="corner tr"></div>
<div class="corner bl"></div>
<div class="corner br"></div>

<!-- Top bar -->
<div id="topbar">
  <div id="logo">AR<span>/</span>Studio</div>
  <div id="status-dot"></div>
</div>

<!-- Toast -->
<div id="toast"></div>

<!-- Ad video -->
<video id="ad" playsinline loop></video>

<!-- Plan label -->
<div id="planLabel" id="planLabel">PLAN 1</div>

<!-- Play/Pause -->
<button id="ppBtn" title="Play / Pause">
  <svg viewBox="0 0 24 24" fill="currentColor" stroke="none" width="18" height="18">
    <path id="ppIcon" d="M8 5v14l11-7z"/>
  </svg>
</button>

<!-- Thumbnails -->
<div class="thumbnail-bar">
  <div class="thumbnail" data-src="advertisement/promo1.mp4" data-label="PLAN">
    <div class="t-num">01</div>
    <div class="t-label">PLAN</div>
  </div>
  <div class="thumbnail" data-src="advertisement/promo2.mp4" data-label="PLAN">
    <div class="t-num">02</div>
    <div class="t-label">PLAN</div>
  </div>
  <div class="thumbnail" data-src="advertisement/promo3.mp4" data-label="PLAN">
    <div class="t-num">03</div>
    <div class="t-label">PLAN</div>
  </div>
</div>

<!-- Bottom bar -->
<div id="bottombar">
  <!-- Mute -->
  <button class="bar-btn" id="muteBtn" title="Mute">
    <svg viewBox="0 0 24 24">
      <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
      <path id="muteWave" d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/>
    </svg>
    <span>Sound</span>
  </button>

  <!-- Share -->
  <button class="bar-btn" id="shareBtn" title="Share">
    <svg viewBox="0 0 24 24">
      <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
      <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
      <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
    </svg>
    <span>Share</span>
  </button>

  <!-- Info -->
  <button class="bar-btn" id="infoBtn" title="Info">
    <svg viewBox="0 0 24 24">
      <circle cx="12" cy="12" r="10"/>
      <line x1="12" y1="8" x2="12" y2="8" stroke-linecap="round" stroke-width="2"/>
      <line x1="12" y1="12" x2="12" y2="16" stroke-linecap="round"/>
    </svg>
    <span>Info</span>
  </button>
</div>

<script>
  /* ── Elements ── */
  const ppBtn     = document.getElementById('ppBtn');
  const ppIcon    = document.getElementById('ppIcon');
  const ad        = document.getElementById('ad');
  const cam       = document.getElementById('cam');
  const thumbnails= document.querySelectorAll('.thumbnail');
  const planLabel = document.getElementById('planLabel');
  const muteBtn   = document.getElementById('muteBtn');
  const muteWave  = document.getElementById('muteWave');
  const shareBtn  = document.getElementById('shareBtn');
  const toast     = document.getElementById('toast');

  let currentVideoSrc = '';
  let muted = false;

  /* ── Toast helper ── */
  let toastTimer;
  function showToast(msg) {
    toast.textContent = msg;
    toast.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => toast.classList.remove('show'), 2200);
  }

  /* ── Camera ── */
  navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } })
    .then(s => cam.srcObject = s)
    .catch(() => navigator.mediaDevices.getUserMedia({ video: true })
      .then(s => cam.srcObject = s)
      .catch(e => showToast('Camera unavailable'))
    );

  /* ── Thumbnails ── */
  thumbnails.forEach(thumb => {
    thumb.addEventListener('click', () => {
      const src = thumb.dataset.src;
      const num = thumb.querySelector('.t-num').textContent;
      if (src === currentVideoSrc) return;

      currentVideoSrc = src;
      ad.src = src;
      ad.load();
      ad.volume = muted ? 0 : 1;
      ad.style.display = 'block';

      // Animate in
      requestAnimationFrame(() => {
        ad.classList.remove('visible');
        requestAnimationFrame(() => ad.classList.add('visible'));
      });

      ad.play().catch(() => {});
      setPause(false);
      ppBtn.style.display = 'flex';

      thumbnails.forEach(t => t.classList.remove('selected'));
      thumb.classList.add('selected');

      planLabel.textContent = `PLAN ${num}`;
      planLabel.classList.add('show');
      setTimeout(() => planLabel.classList.remove('show'), 1600);

      showToast(`Plan ${num} loaded`);
    });
  });

  /* ── Play / Pause ── */
  function setPause(isPaused) {
    ppIcon.setAttribute('d', isPaused
      ? 'M6 19h4V5H6v14zm8-14v14h4V5h-4z'   // pause icon
      : 'M8 5v14l11-7z'                       // play icon
    );
  }

  ppBtn.addEventListener('click', () => {
    if (ad.paused) {
      ad.play().then(() => setPause(false)).catch(() => {});
    } else {
      ad.pause();
      setPause(true);
    }
  });

  /* ── Mute ── */
  muteBtn.addEventListener('click', () => {
    muted = !muted;
    ad.volume = muted ? 0 : 1;
    muteWave.style.display = muted ? 'none' : '';
    showToast(muted ? 'Muted' : 'Sound on');
  });

  /* ── Share ── */
  shareBtn.addEventListener('click', async () => {
    if (navigator.share) {
      try {
        await navigator.share({ title: 'AR Experience', text: 'Check this out!', url: location.href });
      } catch {}
    } else {
      await navigator.clipboard.writeText(location.href).catch(() => {});
      showToast('Link copied');
    }
  });

  /* ── Info ── */
  document.getElementById('infoBtn').addEventListener('click', () => {
    showToast('Select a plan to preview in AR');
  });

  /* ── Security ── */
  document.addEventListener('contextmenu', e => e.preventDefault());
  document.addEventListener('keydown', e => {
    if (
      e.key === 'F12' ||
      (e.ctrlKey && e.shiftKey && ['I','J','C'].includes(e.key.toUpperCase())) ||
      (e.ctrlKey && e.key.toUpperCase() === 'U')
    ) { e.preventDefault(); }
  });
</script>
</body>
</html>
